{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetricAggregateEvent",
  "type": "object",
  "required": ["type", "run_id", "timestamp", "metrics"],
  "properties": {
    "type": { "const": "metric.aggregate" },
    "run_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "metrics": {
      "type": "object",
      "required": ["rps", "error_rate", "cpu_pct", "memory_mb"],
      "properties": {
        "rps": { "type": "number" },
        "error_rate": { "type": "number" },
        "cpu_pct": { "type": "number" },
        "memory_mb": { "type": "number" },
        "latency_ms": {
          "type": "object",
          "properties": {
            "p50": { "type": "number" },
            "p95": { "type": "number" },
            "p99": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

